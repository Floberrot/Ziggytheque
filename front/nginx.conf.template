server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # Public DNS resolver — 127.0.0.11 is Docker Compose only, not available on Railway
    resolver 8.8.8.8 8.8.4.4 valid=30s ipv6=off;

    # Proxy API and cover proxy calls to the backend service.
    # Using a variable forces nginx to re-resolve via the resolver above
    # rather than caching DNS at startup.
    location ~ ^/(api|proxy)/ {
        set $backend ${BACKEND_URL};
        proxy_pass $backend;

        # Required when BACKEND_URL is an HTTPS URL: sends correct SNI and
        # skips certificate verification (inter-service on Railway, no need to verify).
        proxy_ssl_server_name on;
        proxy_ssl_verify     off;

        # Use the upstream host, not the frontend host, so the backend accepts the request.
        proxy_set_header Host              $proxy_host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # SPA fallback: all unknown routes → index.html
    location / {
        try_files $uri $uri/ /index.html;
    }
}
