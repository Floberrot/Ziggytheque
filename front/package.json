{
  "name": "ziggytheque-front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "qa": "npm run lint && npm run type-check && npm run test",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "format": "prettier --write src",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.0",
    "@headlessui/vue": "^1.7.22",
    "@iconify-json/lucide": "^1.2.21",
    "@iconify/vue": "^4.1.2",
    "@tanstack/vue-query": "^5.99.0",
    "@vueuse/core": "^10.11.1",
    "@vueuse/motion": "^2.2.0",
    "axios": "^1.15.0",
    "chart.js": "^4.5.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-chartjs": "^5.3.3",
    "vue-i18n": "^11.3.2",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/fraunces": "^5.1.0",
    "@fontsource-variable/inter": "^5.1.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "axe-core": "^4.8.0",
    "daisyui": "^5.5.19",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.4",
    "vitest": "^4.1.4",
    "vue-tsc": "^3.2.6"
  }
