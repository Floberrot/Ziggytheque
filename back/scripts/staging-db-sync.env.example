# staging-db-sync — configuration (DO NOT COMMIT real values)
#
# 1. Copy this file to:  back/scripts/staging-db-sync.env   (gitignored)
# 2. Fill in the two PUBLIC (proxy) connection URLs.
#
# Where to find them: Railway → service Postgres → onglet "Variables" →
# DATABASE_PUBLIC_URL  (bascule le sélecteur d'environnement pour prod vs staging).
# En CLI : railway variables --service Postgres --environment production
#          railway variables --service Postgres --environment staging
#
# ⚠️ Utilise bien l'URL PUBLIQUE (hôte *.proxy.rlwy.net), PAS l'URL interne
#    *.railway.internal (injoignable depuis ta machine).

# Production database — READ ONLY (a single pg_dump).
PROD_DATABASE_URL="postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway"

# Staging database — OVERWRITTEN then anonymized.
STAGING_DATABASE_URL="postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway"
