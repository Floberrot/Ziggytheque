{
	frankenphp
	order php_server before file_server
}

:{$PORT:80} {
	root * /app/public

	encode zstd br gzip

	route {
		@mercure path /.well-known/mercure*
		header @mercure Access-Control-Allow-Origin "{env.MERCURE_CORS_ORIGINS}"
		header @mercure Access-Control-Allow-Credentials "true"

		mercure {
			publisher_jwt {env.MERCURE_PUBLISHER_JWT_KEY} HS256
			subscriber_jwt {env.MERCURE_SUBSCRIBER_JWT_KEY} HS256
		}

		# FrankenPHP serves PHP via the front controller (Symfony's public/index.php).
		# php_server automatically routes unknown paths to index.php.
		php_server
	}
}
