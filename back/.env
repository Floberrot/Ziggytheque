###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_to_a_random_string_in_production
###< symfony/framework-bundle ###

###> gate-auth ###
GATE_PASSWORD=ziggy123
###< gate-auth ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=ziggy_jwt_passphrase
JWT_TTL=21600
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://ziggy:ziggy@127.0.0.1:5432/ziggytheque?serverVersion=17&charset=utf8"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> messenger-monitor ###
MONITOR_USER=monitor
MONITOR_PASSWORD=monitor
###< messenger-monitor ###

###> manga external apis ###
GOOGLE_BOOKS_API_KEY=change_me
MANGADEX_BASE_URL=https://api.mangadex.org
OPEN_LIBRARY_COVERS_BASE_URL=https://covers.openlibrary.org
OPEN_LIBRARY_BASE_URL=https://openlibrary.org
OPENLIBRARY_USER_AGENT="Ziggytheque/1.0 (contact@ziggytheque.fr)"
GOOGLE_BOOKS_WEB_BASE_URL=https://books.google.com
BNF_BASE_URL=https://catalogue.bnf.fr
# Deutsche Nationalbibliothek SRU — keyless, authoritative for German editions.
DNB_BASE_URL=https://services.dnb.de/sru/dnb
# NDL Search SRU (National Diet Library, Japan) — keyless, authoritative for Japanese editions.
NDL_BASE_URL=https://ndlsearch.ndl.go.jp/api/sru
# AniList GraphQL — keyless, resolves a work's title per language (進撃の巨人 / Attack on Titan).
ANILIST_BASE_URL=https://graphql.anilist.co
# Chasse aux livres — FR book price comparator, queried by ISBN on the volume "Prix" tab.
CHASSE_AUX_LIVRES_BASE_URL=https://www.chasse-aux-livres.fr
# Keyless Google translation endpoint — used to translate manga summaries EN → FR.
GOOGLE_TRANSLATE_BASE_URL=https://translate.googleapis.com
# Hardcover (community DB) — optional ISBN cover source. Leave empty to disable;
# set a personal Bearer token (account settings → Hardcover API) to enable.
HARDCOVER_BASE_URL=https://api.hardcover.app/v1/graphql
HARDCOVER_API_TOKEN=
# eBay Browse API — optional live price source. Leave CLIENT_ID empty to disable.
# Get credentials at developer.ebay.com (App access → OAuth client credentials).
EBAY_BASE_URL=https://api.ebay.com
EBAY_OAUTH_URL=https://api.ebay.com/identity/v1/oauth2/token
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_CAMPAIGN_ID=
###< manga external apis ###

###> mercure ###
MERCURE_PUBLISHER_JWT_KEY=!ChangeThisMercurePublisherSecret32c!
MERCURE_SUBSCRIBER_JWT_KEY=!ChangeThisMercureSubscriberSecret32!
# Hub URL used by back/worker to publish (intra-Docker network)
MERCURE_URL=http://back:80/.well-known/mercure
# Public URL exposed to the SPA
MERCURE_PUBLIC_URL=http://localhost:8000/.well-known/mercure
# Space-separated allowed CORS origins for the Mercure hub
MERCURE_CORS_ORIGINS='http://localhost:5173 http://localhost:8000'
###< mercure ###

###> scan ###
SCAN_TOKEN_SECRET=!ChangeThisScanTokenSecret32chars!!
###< scan ###

###> mailer ###
MAILER_DSN=smtp://mailer:1025
NOTIFICATION_EMAIL=you@example.com
###< mailer ###
DISCORD_WEBHOOK_URL=replace_here
