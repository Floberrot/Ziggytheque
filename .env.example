# Docker Compose reads this file from the project root automatically.
# Copy to .env at the project root and fill in values.
# Symfony-only overrides go in back/.env.local (dev env only).

GATE_PASSWORD=change_me
APP_SECRET=change_me_32_chars_random_string

DATABASE_URL=postgresql://ziggy:ziggy@127.0.0.1:5432/ziggytheque?serverVersion=17&charset=utf8

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me

MONITOR_USER=monitor
MONITOR_PASSWORD=change_me

DISCORD_WEBHOOK_URL=
